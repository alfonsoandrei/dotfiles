# ~/.zshrc.local — machine-specific overrides
# Copy this file to ~/.zshrc.local and fill in your values.
# This file is NOT tracked by git.

# ── Credentials ────────────────────────────────────────────────────────────
export BITBUCKET_APP_PASSWORD_B64=""

# ── AWS CodeArtifact ───────────────────────────────────────────────────────
export CODEARTIFACT_DOMAIN=""
export CODEARTIFACT_DOMAIN_OWNER=""

# ── AWS SSO helpers ────────────────────────────────────────────────────────
ssologin() {
    local profile="${1:-dev}"
    echo "🔍 Checking SSO session for profile: $profile..."
    if AWS_PAGER="" aws sts get-caller-identity --profile "$profile" &>/dev/null; then
        echo "✅ Session already active ($profile), no login needed"
        return 0
    fi
    echo "🚀 Session expired, starting SSO login..."
    AWS_PAGER="" aws sso login --profile "$profile"
}

npmtoken() {
    local profile="${1:-dev}"
    TOKEN=$(AWS_PAGER="" aws codeartifact get-authorization-token \
        --domain "$CODEARTIFACT_DOMAIN" \
        --domain-owner "$CODEARTIFACT_DOMAIN_OWNER" \
        --query authorizationToken \
        --output text \
        --region us-east-1 \
        --profile "$profile")
    export CODEARTIFACT_AUTH_TOKEN="${TOKEN}"
    echo "✅ New CODEARTIFACT_AUTH_TOKEN set"
}

dev-login() {
    if ssologin dev; then
        npmtoken dev
    else
        echo "Aborting npmtoken because login failed."
    fi
}

# ── SCM logs ───────────────────────────────────────────────────────────────
alias scm-logs='nvim -n "term://tail -f /tmp/scm-debug.log"'
alias scm-pretty='node ~/.scripts/log-pretty.mjs'

# ── Other work-specific aliases / PATH additions ───────────────────────────
# export PATH="$PATH:/path/to/work/tools"
